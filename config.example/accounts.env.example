# Copy to ~/.config/jira-multi/accounts.env  (chmod 600 — holds API tokens)
#
# One block per Atlassian LOGIN. A single API token works on EVERY site that
# login email can access, so accounts sharing an email share a token
# (scripts/jira-token-add.sh fills them all at once).
#
# Create tokens: https://id.atlassian.com/manage-profile/security/api-tokens
# (log in as the right email first — SSO reuses the wrong account silently;
# use an incognito window). Tokens expire after max 1 year.

# <NAME> becomes the lowercase account name used everywhere (here: "work")
WORK_SITE=mycompany          # → mycompany.atlassian.net
WORK_EMAIL=me@mycompany.com
#WORK_TOKEN=

PERSONAL_SITE=myspace
PERSONAL_EMAIL=me@gmail.com
#PERSONAL_TOKEN=

# CLIENTX_SITE=clientx
# CLIENTX_EMAIL=me@gmail.com     # same email as PERSONAL → same token
# #CLIENTX_TOKEN=
