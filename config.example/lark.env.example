# Copy to ~/.config/jira-multi/lark.env  (chmod 600 — holds the app secret)
#
# Lark Suite / Feishu support runs on the OFFICIAL lark-openapi-mcp server
# (@larksuiteoapi/lark-mcp); this file only feeds scripts/lark-add.sh which
# registers it for Claude Code.
#
# Create an app at the open platform, enable the permissions you need
# (tasks: task:task; docs: docx:document, wiki:wiki, drive:drive), publish,
# then copy the App ID + App Secret from "Credentials & Basic Info":
#   International Lark: https://open.larksuite.com
#   Feishu (China):     https://open.feishu.cn

LARK_APP_ID=cli_xxxxxxxxxxxxxxxxx
LARK_APP_SECRET=

# open.larksuite.com for international Lark; open.feishu.cn for Feishu (default)
LARK_DOMAIN=https://open.larksuite.com

# tenant = app acts as itself (simplest); user = acts as YOU via OAuth
# (user mode: tasks/docs are created in your name — needs --oauth login once)
LARK_TOKEN_MODE=tenant

# MCP tools to expose (comma-separated presets/tools). Default = task + docs.
LARK_TOOLS=preset.task.default,preset.doc.default
