# Copy to ~/.config/jira-multi/map.env  (no secrets — folder→account mapping)
#
#   <folder-name>=<account>[:<JIRA-PROJECT-KEY>[:<CONFLUENCE-SPACE-KEY>]]
#
# <folder-name> is the directory basename; the resolver walks up from cwd, so
# a mapping matches the repo root even when you're deep inside it.
# Accounts = the names defined in accounts.env (work / personal / ...).
# PROJECT-KEY is the default project for issue creation in that folder.
# SPACE-KEY additionally enables the Confluence status page in roadmap-sync.

# Fallback when nothing matches (otherwise: folder name containing an account
# name wins, then the only configured account):
default=work

# my-backend=work:BACK
# my-frontend=work:FRONT
# side-project=personal:SIDE:SIDE
